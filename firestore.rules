rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── 헬퍼 함수 ───────────────────────────────────────────
    // 학교 이메일 + 인증 완료된 사용자만 인증 상태로 인정
    function isAuthed() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('.*@dshs[.]kr');
    }
    function isVerified() {
      return isAuthed();  // 별칭 (가독성)
    }
    function getMapping() {
      return get(/databases/$(database)/documents/userMappings/$(request.auth.uid)).data;
    }
    function getRole() {
      return getMapping().role;
    }
    function getMyLegacyId() {
      return getMapping().legacyId;
    }
    function hasMapping() {
      return isAuthed() && exists(/databases/$(database)/documents/userMappings/$(request.auth.uid));
    }
    function isAdmin() {
      return hasMapping() && getRole() == 'admin';
    }
    function isStaff() {
      return hasMapping() && getRole() in ['admin', 'teacher', 'leader'];
    }

    // ─── userMappings: Firebase UID ↔ legacy 학생 ID 매핑 ─────
    match /userMappings/{uid} {
      // 본인 매핑만 읽기 가능
      allow read: if isAuthed() && request.auth.uid == uid;

      // 회원가입 시 1회 생성: 본인 UID로만, 미점유 legacyId 만, role 일치 검증
      allow create: if isVerified()
        && request.auth.uid == uid
        && exists(/databases/$(database)/documents/users/$(request.resource.data.legacyId))
        && get(/databases/$(database)/documents/users/$(request.resource.data.legacyId)).data.firebase_uid == null
        && request.resource.data.role == get(/databases/$(database)/documents/users/$(request.resource.data.legacyId)).data.role;

      // 매핑은 변경/삭제 불가 (관리자는 Admin SDK로 직접 처리)
      allow update, delete: if false;
    }

    // ─── users: 학생/선생/관리자 프로필 ──────────────────────
    match /users/{userId} {
      // 모든 인증 사용자는 read 가능 (이름+반 매칭 + 역할 표시)
      allow read: if isAuthed();

      // 본인이 firebase_uid + email 만 1회 설정 가능 (회원가입 매칭)
      // 또는 admin이 모든 필드 변경 가능
      allow update: if (
        isVerified()
        && resource.data.firebase_uid == null
        && request.resource.data.firebase_uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['firebase_uid', 'email'])
      ) || isAdmin();

      allow create, delete: if isAdmin();
    }

    // ─── 과목/분반/수강 (admin만 수정) ──────────────────────
    match /subjects/{id} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }
    match /classes/{id} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }
    match /enrollments/{id} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // ─── 수행평가/공지 (스태프만 작성) ──────────────────────
    match /assignments/{id} {
      allow read: if isAuthed();
      allow write: if isStaff();
    }
    match /notices/{id} {
      allow read: if isAuthed();
      allow write: if isStaff();
    }

    // ─── 댓글 (본인 것만 작성/수정) ─────────────────────────
    match /assignment_comments/{id} {
      allow read: if isAuthed();
      allow create: if hasMapping() && request.resource.data.writer == getMyLegacyId();
      allow update: if hasMapping() && resource.data.writer == getMyLegacyId();
      allow delete: if hasMapping() && (resource.data.writer == getMyLegacyId() || isAdmin());
    }
    match /notice_comments/{id} {
      allow read: if isAuthed();
      allow create: if hasMapping() && request.resource.data.writer == getMyLegacyId();
      allow update: if hasMapping() && resource.data.writer == getMyLegacyId();
      allow delete: if hasMapping() && (resource.data.writer == getMyLegacyId() || isAdmin());
    }

    // ─── 읽음/완료 (본인 것만) ──────────────────────────────
    match /comment_reads/{id} {
      allow read: if hasMapping() && resource.data.user_id == getMyLegacyId();
      allow create: if hasMapping() && request.resource.data.user_id == getMyLegacyId();
      allow update, delete: if false;
    }
    match /notice_reads/{id} {
      allow read: if hasMapping() && resource.data.user_id == getMyLegacyId();
      allow create: if hasMapping() && request.resource.data.user_id == getMyLegacyId();
      allow update, delete: if false;
    }
    match /completions/{id} {
      allow read: if hasMapping() && resource.data.user_id == getMyLegacyId();
      allow create, update: if hasMapping() && request.resource.data.user_id == getMyLegacyId();
      allow delete: if hasMapping() && resource.data.user_id == getMyLegacyId();
    }

    // ─── 개인 일정 (본인 것만) ──────────────────────────────
    match /personal_events/{id} {
      allow read: if hasMapping() && resource.data.user_id == getMyLegacyId();
      allow create: if hasMapping() && request.resource.data.user_id == getMyLegacyId();
      allow update, delete: if hasMapping() && resource.data.user_id == getMyLegacyId();
    }

    // ─── 시간표 (본인 것만 수정) ────────────────────────────
    match /timetables/{userId} {
      allow read: if isAuthed();
      allow write: if hasMapping() && userId == getMyLegacyId();
    }

    // ─── 크롤러/토큰 ─────────────────────────────────────
    match /coursework/{id} {
      // 본인이 크롤한 coursework 만 학생이 read 가능 (admin 은 전체 read)
      allow read: if hasMapping() && (
        resource.data.fetched_by == getMyLegacyId() || isAdmin()
      );
      // 즉시 크롤 (Cloudflare Worker → 브라우저) 가 본인 fetched_by 데이터만 write
      allow create, update: if hasMapping() && request.resource.data.fetched_by == getMyLegacyId();
      allow delete: if false;  // Admin SDK 만 삭제 (cleanup workflow)
    }
    match /tokens/{id} {
      // 본인 토큰 read + admin 은 전체 read
      allow read: if hasMapping() && (
        resource.data.user_id == getMyLegacyId() || isAdmin()
      );
      // 즉시 크롤: Worker 가 교환한 토큰을 브라우저가 본인 user_id 로 write
      allow create, update: if hasMapping() && request.resource.data.user_id == getMyLegacyId();
      allow delete: if false;
    }
    // 동의 직후 임시 보관되는 OAuth 코드. 본인 docId 만 쓰기 가능, 5분 안에 GH Actions 가 교환 후 삭제.
    match /pendingTokens/{userId} {
      allow read, create, update: if hasMapping() && userId == getMyLegacyId();
      allow delete: if false;  // Admin SDK 만 삭제
    }

    // ─── 급식 사진/학사 일정 (인증 read, admin write) ───────
    match /meal_day_images/{id} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }
    match /school_schedule/{id} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }
  }
}
